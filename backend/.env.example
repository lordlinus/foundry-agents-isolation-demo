# =============================================================================
# Hosted Agents Demo — backend proxy configuration
# =============================================================================

# --- Foundry hosted agent ---------------------------------------------------
# Project endpoint of your Foundry project (without trailing slash).
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>

# Name of the deployed hosted agent (must match `name:` in agent.yaml).
FOUNDRY_AGENT_NAME=docs-helper-agent

# Override only if you know what you're doing.
# FOUNDRY_API_VERSION=v1
# FOUNDRY_FEATURES=HostedAgents=V1Preview,AgentEndpoints=V1Preview

# --- Observability hint shown in the UI -------------------------------------
# Friendly name of the Application Insights instance attached to your Foundry
# project. The UI builds a KQL hint so demos can jump straight to traces.
APPINSIGHTS_NAME=appi-hosted-agents-demo

# --- Misc -------------------------------------------------------------------
PORT=8000
