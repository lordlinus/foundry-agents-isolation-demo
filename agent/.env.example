# Required when running the agent locally (`python main.py`):
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini

# Optional: register the GitHub Copilot MCP server too.
# GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Override the Microsoft Learn MCP endpoint if needed.
# MS_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp
